<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RadioAficionado.Escritorio.ViewModels"
             x:Class="RadioAficionado.Escritorio.Vistas.PanelPropagacion"
             x:DataType="vm:PanelPropagacionViewModel">

    <DockPanel>
        <!-- Barra inferior: estado -->
        <Border DockPanel.Dock="Bottom" Background="#0f3460" Padding="8,4">
            <TextBlock Text="{Binding TextoEstado}" Foreground="#aaaaaa" FontSize="11" />
        </Border>

        <Grid RowDefinitions="Auto,*">
            <!-- Panel superior: Índices solares -->
            <Border Grid.Row="0" Background="#16213e" CornerRadius="4" Padding="12" Margin="8,8,8,4">
                <DockPanel>
                    <!-- Título y botón actualizar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,10">
                        <TextBlock Text="Índices Solares" Foreground="White" FontWeight="Bold" FontSize="16"
                                   VerticalAlignment="Center" />
                        <Border Background="#0f3460" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding EstadoGeomagnetico}"
                                       Foreground="{Binding ColorEstadoGeomagnetico}"
                                       FontWeight="Bold" FontSize="11" />
                        </Border>
                        <TextBlock Text="{Binding UltimaActualizacion}" Foreground="#666666" FontSize="11"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />

                        <!-- Espaciador -->
                        <Border HorizontalAlignment="Stretch" />

                        <Button Content="Actualizar"
                                Command="{Binding ActualizarTodoCommand}"
                                IsEnabled="{Binding !Procesando}"
                                Background="#e94560"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="12,4"
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right" />
                    </StackPanel>

                    <!-- Grid de índices -->
                    <Grid ColumnDefinitions="*,*,*,*" HorizontalAlignment="Stretch">
                        <!-- SFI -->
                        <Border Grid.Column="0" Background="#0f3460" CornerRadius="8" Padding="12,8" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="SFI" Foreground="#aaaaaa" FontSize="11"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Sfi}" Foreground="{Binding ColorSfi}"
                                           FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Solar Flux" Foreground="#555555" FontSize="9"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Kp -->
                        <Border Grid.Column="1" Background="#0f3460" CornerRadius="8" Padding="12,8" Margin="4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Kp" Foreground="#aaaaaa" FontSize="11"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Kp}" Foreground="{Binding ColorKp}"
                                           FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Geomagnético" Foreground="#555555" FontSize="9"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Ap -->
                        <Border Grid.Column="2" Background="#0f3460" CornerRadius="8" Padding="12,8" Margin="4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Ap" Foreground="#aaaaaa" FontSize="11"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Ap}" Foreground="#aaaaaa"
                                           FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Índice A" Foreground="#555555" FontSize="9"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- SSN -->
                        <Border Grid.Column="3" Background="#0f3460" CornerRadius="8" Padding="12,8" Margin="4,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="SSN" Foreground="#aaaaaa" FontSize="11"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Ssn, StringFormat={}{0:F0}}" Foreground="#aaaaaa"
                                           FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Manchas Solares" Foreground="#555555" FontSize="9"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Panel inferior: Predicciones por banda -->
            <Border Grid.Row="1" Background="#16213e" CornerRadius="4" Padding="12" Margin="8,4,8,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Predicción por Banda HF"
                               Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />

                    <!-- Encabezados -->
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="100,80,*,120,*"
                          Margin="4,0,4,4">
                        <TextBlock Grid.Column="0" Text="Banda" Foreground="#888888" FontWeight="Bold" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="Nivel" Foreground="#888888" FontWeight="Bold" FontSize="11" />
                        <TextBlock Grid.Column="2" Text="Descripción" Foreground="#888888" FontWeight="Bold" FontSize="11" />
                        <TextBlock Grid.Column="3" Text="Mejor Hora" Foreground="#888888" FontWeight="Bold" FontSize="11" />
                        <TextBlock Grid.Column="4" Text="Regiones" Foreground="#888888" FontWeight="Bold" FontSize="11" />
                    </Grid>

                    <Border DockPanel.Dock="Top" Height="1" Background="#333333" Margin="0,0,0,4" />

                    <!-- Lista de predicciones -->
                    <ListBox ItemsSource="{Binding Predicciones}" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PrediccionBandaVm">
                                <Grid ColumnDefinitions="100,80,*,120,*" Margin="0,2">
                                    <!-- Nombre de la banda -->
                                    <TextBlock Grid.Column="0" Text="{Binding NombreBanda}"
                                               Foreground="White" FontWeight="Bold" FontSize="12"
                                               VerticalAlignment="Center" />

                                    <!-- Nivel con color -->
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding ColorNivel}" Opacity="0.2" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding Nivel}"
                                                   Foreground="{Binding ColorNivel}"
                                                   FontWeight="Bold" FontSize="11" />
                                    </Border>

                                    <!-- Descripción -->
                                    <TextBlock Grid.Column="2" Text="{Binding Descripcion}"
                                               Foreground="#aaaaaa" FontSize="11"
                                               TextWrapping="Wrap" VerticalAlignment="Center" />

                                    <!-- Mejor hora -->
                                    <TextBlock Grid.Column="3" Text="{Binding MejorHora}"
                                               Foreground="#888888" FontFamily="Consolas" FontSize="11"
                                               VerticalAlignment="Center" />

                                    <!-- Regiones -->
                                    <TextBlock Grid.Column="4" Text="{Binding Regiones}"
                                               Foreground="#666666" FontSize="10"
                                               TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
