<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RadioAficionado.Escritorio.ViewModels"
             xmlns:controles="using:RadioAficionado.Escritorio.Controles"
             x:Class="RadioAficionado.Escritorio.Vistas.PanelWaterfall"
             x:DataType="vm:PanelWaterfallViewModel">

    <Border Background="#16213e" CornerRadius="4" Padding="10">
        <DockPanel>
            <!-- Barra superior: titulo, controles y estado -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="0,0,0,8">
                <TextBlock Grid.Column="0"
                           Text="Waterfall"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center" />

                <!-- Estado -->
                <Border Grid.Column="2" Background="#0f3460" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                    <TextBlock Text="{Binding EstadoWaterfall}" Foreground="#e94560" FontSize="12" />
                </Border>

                <!-- Implementacion FFT -->
                <Border Grid.Column="3" Background="#533483" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                    <TextBlock Text="{Binding ImplementacionFft, StringFormat=FFT: {0}}" Foreground="White" FontSize="11" />
                </Border>

                <!-- Botones -->
                <Button Grid.Column="4"
                        Content="Iniciar"
                        Command="{Binding IniciarWaterfallCommand}"
                        Background="#e94560"
                        Foreground="White"
                        Padding="10,4"
                        Margin="0,0,6,0" />
                <Button Grid.Column="5"
                        Content="Detener"
                        Command="{Binding DetenerWaterfallCommand}"
                        Background="#0f3460"
                        Foreground="White"
                        Padding="10,4" />
            </Grid>

            <!-- Selector de tamano FFT -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="Tamano FFT:" Foreground="#aaaaaa" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding TamanosDisponibles}"
                          SelectedItem="{Binding TamanoFft}"
                          Height="30" />
            </StackPanel>

            <!-- Control de waterfall -->
            <Border Background="#0a0a23" CornerRadius="4">
                <controles:ControlWaterfall x:Name="WaterfallControl"
                                            AnchoFft="1025"
                                            DbMinimo="-120"
                                            DbMaximo="0"
                                            ClipToBounds="True" />
            </Border>
        </DockPanel>
    </Border>
</UserControl>
