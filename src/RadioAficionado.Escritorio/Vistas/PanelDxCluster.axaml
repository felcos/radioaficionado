<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RadioAficionado.Escritorio.ViewModels"
             x:Class="RadioAficionado.Escritorio.Vistas.PanelDxCluster"
             x:DataType="vm:PanelDxClusterViewModel">

    <Border Background="#16213e" CornerRadius="4" Padding="8">
        <DockPanel>
            <!-- Barra superior: conexión -->
            <Border DockPanel.Dock="Top" Background="#0f3460" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                    <!-- Fila 1: Servidor + Indicativo + Botón -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Servidor:" Foreground="#aaaaaa" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding Servidores}"
                                  SelectedItem="{Binding ServidorSeleccionado}"
                                  MinWidth="280"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ServidorDxClusterVm">
                                    <TextBlock Text="{Binding DisplayText}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="10,0">
                        <TextBlock Text="Indicativo:" Foreground="#aaaaaa" VerticalAlignment="Center" />
                        <TextBox Text="{Binding IndicativoPropio}"
                                 Watermark="TU INDICATIVO"
                                 MinWidth="120"
                                 VerticalAlignment="Center"
                                 FontFamily="Consolas"
                                 />
                    </StackPanel>

                    <Button Grid.Row="0" Grid.Column="2"
                            Content="{Binding TextoBotonConexion}"
                            Command="{Binding AlternarConexionCommand}"
                            MinWidth="100"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center" />

                    <!-- Fila 2: Filtros -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                        <TextBlock Text="Filtrar:" Foreground="#aaaaaa" VerticalAlignment="Center" />
                        <TextBox Text="{Binding FiltroIndicativo}"
                                 Watermark="Indicativo..."
                                 MinWidth="120"
                                 VerticalAlignment="Center"
                                 FontFamily="Consolas"
                                 />
                        <TextBlock Text="Banda:" Foreground="#aaaaaa" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <ComboBox ItemsSource="{Binding BandasDisponibles}"
                                  SelectedItem="{Binding FiltroBanda}"
                                  MinWidth="100"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="Modo:" Foreground="#aaaaaa" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <ComboBox ItemsSource="{Binding ModosDisponibles}"
                                  SelectedItem="{Binding FiltroModo}"
                                  MinWidth="100"
                                  VerticalAlignment="Center" />
                        <Button Content="Limpiar"
                                Command="{Binding LimpiarSpotsCommand}"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="{Binding TotalSpots, StringFormat=Spots: {0}}"
                               Foreground="#888888"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,6,0,0" />
                </Grid>
            </Border>

            <!-- Barra de estado inferior -->
            <Border DockPanel.Dock="Bottom" Background="#0a0a23" CornerRadius="2" Padding="6,3" Margin="0,4,0,0">
                <TextBlock Text="{Binding TextoEstado}"
                           Foreground="#888888"
                           FontSize="11"
                           FontFamily="Consolas" />
            </Border>

            <!-- Encabezado de columnas -->
            <Border DockPanel.Dock="Top" Background="#0a0a23" CornerRadius="2" Padding="6,4" Margin="0,0,0,2">
                <Grid ColumnDefinitions="55,90,100,90,65,*">
                    <TextBlock Grid.Column="0" Text="Hora" Foreground="#888888" FontWeight="Bold" FontSize="11" FontFamily="Consolas" />
                    <TextBlock Grid.Column="1" Text="DX" Foreground="#e94560" FontWeight="Bold" FontSize="11" FontFamily="Consolas" />
                    <TextBlock Grid.Column="2" Text="Frecuencia" Foreground="#888888" FontWeight="Bold" FontSize="11" FontFamily="Consolas" />
                    <TextBlock Grid.Column="3" Text="Spotter" Foreground="#888888" FontWeight="Bold" FontSize="11" FontFamily="Consolas" />
                    <TextBlock Grid.Column="4" Text="Modo" Foreground="#888888" FontWeight="Bold" FontSize="11" FontFamily="Consolas" />
                    <TextBlock Grid.Column="5" Text="Comentario" Foreground="#888888" FontWeight="Bold" FontSize="11" FontFamily="Consolas" />
                </Grid>
            </Border>

            <!-- Lista de spots -->
            <ListBox ItemsSource="{Binding SpotsVisibles}"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="6,2" />
                        <Setter Property="MinHeight" Value="24" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#22e94560" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#33e94560" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SpotDxVm">
                        <Grid ColumnDefinitions="55,90,100,90,65,*">
                            <TextBlock Grid.Column="0" Text="{Binding Hora}"
                                       Foreground="#666666" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding IndicativoDx}"
                                       Foreground="#e94560" FontWeight="Bold" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding FrecuenciaDisplay}"
                                       Foreground="#00ff88" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding IndicativoSpotter}"
                                       Foreground="#aaaaaa" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding Modo}"
                                       Foreground="#ffcc00" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="{Binding Comentario}"
                                       Foreground="#888888" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
