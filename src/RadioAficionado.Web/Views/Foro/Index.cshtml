@model ForoIndexViewModel
@{
    ViewData["Title"] = "Foro";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6 mb-0">Foro de la Comunidad</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="CrearHilo" class="btn btn-ra-acento">Nuevo hilo</a>
    }
</div>

<!-- Filtro por categoría -->
<div class="mb-4">
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index"
           class="btn btn-sm @(Model.FiltroCategoria == null ? "btn-ra-acento" : "btn-outline-ra-acento")">
            Todas
        </a>
        @foreach (RadioAficionado.Dominio.Entidades.CategoriaForo categoria in Enum.GetValues<RadioAficionado.Dominio.Entidades.CategoriaForo>())
        {
            <a asp-action="Index" asp-route-categoria="@((int)categoria)"
               class="btn btn-sm @(Model.FiltroCategoria == categoria ? "btn-ra-acento" : "btn-outline-ra-acento")">
                @ObtenerNombreCategoria(categoria)
            </a>
        }
    </div>
</div>

@if (Model.Hilos.Count == 0)
{
    <div class="card bg-ra-tarjeta border-ra-borde p-5 text-center">
        <p class="text-ra-suave mb-0">No hay hilos en esta categoría. ¡Sé el primero en crear uno!</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table tabla-ra table-hover">
            <thead>
                <tr>
                    <th style="width: 50%">Hilo</th>
                    <th class="text-center">Respuestas</th>
                    <th>Autor</th>
                    <th>Última actividad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (HiloResumenViewModel hilo in Model.Hilos)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-start gap-2">
                                <div>
                                    @if (hilo.Fijado)
                                    {
                                        <span class="badge bg-warning text-dark me-1" title="Fijado">Fijado</span>
                                    }
                                    @if (hilo.Cerrado)
                                    {
                                        <span class="badge bg-secondary me-1" title="Cerrado">Cerrado</span>
                                    }
                                    <a asp-action="Detalle" asp-route-id="@hilo.Id" class="text-ra-acento text-decoration-none fw-semibold">
                                        @hilo.Titulo
                                    </a>
                                    <br />
                                    <span class="badge bg-ra-modo mt-1">@ObtenerNombreCategoria(hilo.Categoria)</span>
                                </div>
                            </div>
                        </td>
                        <td class="text-center align-middle">
                            <span class="fw-semibold">@hilo.NumeroRespuestas</span>
                        </td>
                        <td class="align-middle">
                            <span class="text-ra-acento">@hilo.AutorIndicativo</span>
                            <br />
                            <small class="text-ra-suave">@hilo.AutorNombre</small>
                        </td>
                        <td class="align-middle">
                            <small class="text-ra-suave">@hilo.FechaUltimaRespuesta.ToString("dd/MM/yyyy HH:mm") UTC</small>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPaginas > 1)
    {
        <nav aria-label="Paginación del foro">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link bg-ra-tarjeta border-ra-borde text-ra-acento"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PaginaActual - 1)"
                       asp-route-categoria="@((int?)Model.FiltroCategoria)">
                        Anterior
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link @(i == Model.PaginaActual ? "bg-ra-acento-solido border-ra-borde text-dark" : "bg-ra-tarjeta border-ra-borde text-ra-acento")"
                           asp-action="Index"
                           asp-route-pagina="@i"
                           asp-route-categoria="@((int?)Model.FiltroCategoria)">
                            @i
                        </a>
                    </li>
                }
                <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link bg-ra-tarjeta border-ra-borde text-ra-acento"
                       asp-action="Index"
                       asp-route-pagina="@(Model.PaginaActual + 1)"
                       asp-route-categoria="@((int?)Model.FiltroCategoria)">
                        Siguiente
                    </a>
                </li>
            </ul>
        </nav>
    }
}

@functions {
    static string ObtenerNombreCategoria(RadioAficionado.Dominio.Entidades.CategoriaForo categoria)
    {
        return categoria switch
        {
            RadioAficionado.Dominio.Entidades.CategoriaForo.General => "General",
            RadioAficionado.Dominio.Entidades.CategoriaForo.Tecnico => "Técnico",
            RadioAficionado.Dominio.Entidades.CategoriaForo.DX => "DX",
            RadioAficionado.Dominio.Entidades.CategoriaForo.Contests => "Contests",
            RadioAficionado.Dominio.Entidades.CategoriaForo.Activaciones => "Activaciones",
            RadioAficionado.Dominio.Entidades.CategoriaForo.Compraventa => "Compraventa",
            _ => categoria.ToString()
        };
    }
}
