@model CrearHiloViewModel
@{
    ViewData["Title"] = "Nuevo hilo";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Foro" asp-action="Index" class="text-ra-acento text-decoration-none">Foro</a>
        </li>
        <li class="breadcrumb-item active text-ra-suave" aria-current="page">Nuevo hilo</li>
    </ol>
</nav>

<h1 class="display-6 mb-4">Crear nuevo hilo</h1>

<div class="card bg-ra-tarjeta border-ra-borde">
    <div class="card-body">
        <form asp-action="CrearHilo" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Titulo" class="form-label text-ra-suave"></label>
                <input asp-for="Titulo" class="form-control bg-ra-input border-ra-borde" placeholder="Título del hilo" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Categoria" class="form-label text-ra-suave"></label>
                <select asp-for="Categoria" class="form-select bg-ra-input border-ra-borde">
                    <option value="@((int)RadioAficionado.Dominio.Entidades.CategoriaForo.General)">General</option>
                    <option value="@((int)RadioAficionado.Dominio.Entidades.CategoriaForo.Tecnico)">Técnico</option>
                    <option value="@((int)RadioAficionado.Dominio.Entidades.CategoriaForo.DX)">DX</option>
                    <option value="@((int)RadioAficionado.Dominio.Entidades.CategoriaForo.Contests)">Contests</option>
                    <option value="@((int)RadioAficionado.Dominio.Entidades.CategoriaForo.Activaciones)">Activaciones</option>
                    <option value="@((int)RadioAficionado.Dominio.Entidades.CategoriaForo.Compraventa)">Compraventa</option>
                </select>
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contenido" class="form-label text-ra-suave"></label>
                <textarea asp-for="Contenido" class="form-control bg-ra-input border-ra-borde" rows="8"
                          placeholder="Escribe el contenido de tu hilo..."></textarea>
                <span asp-validation-for="Contenido" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-ra-acento">Publicar hilo</button>
                <a asp-action="Index" class="btn btn-outline-ra-acento">Cancelar</a>
            </div>
        </form>
    </div>
</div>
