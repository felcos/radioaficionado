@{
    ViewData["Title"] = "Software de Radio Amateur Todo-en-Uno";
    ViewData["SinContainer"] = true;
}

<!-- Hero Section -->
<section class="landing-hero text-center py-5">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3">
            <span class="text-ra-verde">Radio</span>Aficionado
        </h1>
        <p class="lead text-ra-suave mx-auto mb-4" style="max-width: 700px;">
            Software de radio amateur todo-en-uno. Logbook, modos digitales, control de radio,
            espectro, propagacion y mucho mas — todo desde una sola plataforma.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="#" class="btn btn-landing-verde btn-lg px-4">
                Descargar App de Escritorio
            </a>
            <a asp-controller="Cuenta" asp-action="Registrar" class="btn btn-outline-landing-verde btn-lg px-4">
                Crear Cuenta Gratis
            </a>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-5" id="features">
    <div class="container">
        <h2 class="text-center text-ra-verde mb-2">Funcionalidades</h2>
        <p class="text-center text-ra-suave mb-5">Todo lo que un radioaficionado necesita en un solo lugar</p>
        <div class="row g-4">
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128214;</div>
                        <h3 class="h6 text-ra-verde">Logbook</h3>
                        <p class="text-ra-suave small mb-0">
                            Registro de QSOs con filtros, paginacion y formato ADIF 3.1.4.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#127760;</div>
                        <h3 class="h6 text-ra-verde">DX Cluster</h3>
                        <p class="text-ra-suave small mb-0">
                            Spots en tiempo real de estaciones DX activas en todas las bandas.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#127919;</div>
                        <h3 class="h6 text-ra-verde">DXCC Tracking</h3>
                        <p class="text-ra-suave small mb-0">
                            Seguimiento de entidades DXCC trabajadas y confirmadas.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#9728;&#65039;</div>
                        <h3 class="h6 text-ra-verde">Propagacion Solar</h3>
                        <p class="text-ra-suave small mb-0">
                            Indices solares, predicciones de propagacion HF y alertas.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128225;</div>
                        <h3 class="h6 text-ra-verde">Modos Digitales (FT8)</h3>
                        <p class="text-ra-suave small mb-0">
                            Decodificacion nativa de FT8, FT4, JT65, JT9, WSPR y mas.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128251;</div>
                        <h3 class="h6 text-ra-verde">Control de Radio CAT</h3>
                        <p class="text-ra-suave small mb-0">
                            Control directo de tu radio via CAT/CI-V con rigctld o serie.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#127912;</div>
                        <h3 class="h6 text-ra-verde">Espectro / Waterfall</h3>
                        <p class="text-ra-suave small mb-0">
                            Visualizacion de espectro en tiempo real con FFT de alta resolucion.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128736;</div>
                        <h3 class="h6 text-ra-verde">Herramientas</h3>
                        <p class="text-ra-suave small mb-0">
                            Generador QSL, mapa de contactos, estadisticas y mas utilidades.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Descarga -->
<section class="py-5 landing-descarga-section" id="descarga">
    <div class="container text-center">
        <h2 class="text-ra-verde mb-3">Descarga la App de Escritorio</h2>
        <p class="text-ra-suave mx-auto mb-4" style="max-width: 600px;">
            Disponible para Windows, Linux y macOS. Interfaz nativa con Avalonia, rendimiento nativo
            y sin dependencias externas.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="#" class="btn btn-landing-verde btn-lg px-4">
                Windows (x64)
            </a>
            <a href="#" class="btn btn-outline-landing-verde btn-lg px-4">
                Linux (x64)
            </a>
            <a href="#" class="btn btn-outline-landing-verde btn-lg px-4">
                macOS (arm64)
            </a>
        </div>
        <p class="text-ra-suave small mt-3">Requiere .NET 8 Runtime</p>
    </div>
</section>

<!-- Comunidad -->
<section class="py-5" id="comunidad">
    <div class="container text-center">
        <h2 class="text-ra-verde mb-3">Unete a la Comunidad</h2>
        <p class="text-ra-suave mx-auto mb-4" style="max-width: 600px;">
            Registrate gratis para obtener tu perfil publico de operador, participar en el foro,
            acceder a estadisticas avanzadas y compartir tu logbook con otros radioaficionados.
        </p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128100;</div>
                        <h3 class="h6 text-ra-verde">Perfil Publico</h3>
                        <p class="text-ra-suave small mb-0">
                            Tu tarjeta de presentacion como operador con indicativo, localizador y estadisticas.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128172;</div>
                        <h3 class="h6 text-ra-verde">Foro</h3>
                        <p class="text-ra-suave small mb-0">
                            Comparte experiencias, resuelve dudas y conecta con otros radioaficionados.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card landing-feature-card h-100">
                    <div class="card-body text-center">
                        <div class="landing-feature-icon mb-3">&#128200;</div>
                        <h3 class="h6 text-ra-verde">Estadisticas</h3>
                        <p class="text-ra-suave small mb-0">
                            Graficos de bandas, modos, continentes y evolucion temporal de tu actividad.
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-5">
            <a asp-controller="Cuenta" asp-action="Registrar" class="btn btn-landing-verde btn-lg px-5">
                Registrarse Gratis
            </a>
            <p class="text-ra-suave small mt-2">
                Ya tienes cuenta?
                <a asp-controller="Cuenta" asp-action="IniciarSesion" class="text-ra-verde text-decoration-none">
                    Inicia sesion
                </a>
            </p>
        </div>
    </div>
</section>
