@{
    ViewData["Title"] = "Propagacion Solar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Propagacion Solar</h2>
        <p class="text-muted mb-0">Datos en tiempo real de NOAA — Space Weather Prediction Center</p>
    </div>
    <div>
        <button class="btn btn-outline-light" id="btn-actualizar-solar">Actualizar datos</button>
        <span class="ms-2 text-muted small" id="solar-actualizacion"></span>
    </div>
</div>

<!-- Indices principales -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small text-uppercase">Solar Flux Index (SFI)</div>
                <div class="fs-2 fw-bold" id="solar-sfi">--</div>
                <div class="text-muted" style="font-size: 0.7rem;">Mayor = mejor propagacion HF</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small text-uppercase">Kp Index</div>
                <div class="fs-2 fw-bold" id="solar-kp">--</div>
                <div class="text-muted" style="font-size: 0.7rem;">Menor = propagacion mas estable</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small text-uppercase">A Index</div>
                <div class="fs-2 fw-bold" id="solar-a">--</div>
                <div class="text-muted" style="font-size: 0.7rem;">Menor = menos perturbacion geomagnetica</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small text-uppercase">Viento Solar</div>
                <div class="fs-3 fw-bold" id="solar-viento-vel">--</div>
                <div class="text-muted" style="font-size: 0.7rem;">&lt;400 tranquilo | 400-600 elevado | &gt;600 alto</div>
            </div>
        </div>
    </div>
</div>

<!-- Segunda fila: Campo magnetico -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Bt (magnitud total)</div>
                <div class="fs-5 fw-bold" id="solar-bt">--</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Bz (componente norte-sur)</div>
                <div class="fs-5 fw-bold" id="solar-bz">--</div>
                <div class="text-muted" style="font-size: 0.65rem;">Negativo = posible tormenta geomagnetica</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Interpretacion</div>
                <div class="small mt-1">
                    <span class="text-success">SFI alto + Kp bajo</span> = Propagacion HF excelente<br>
                    <span class="text-danger">Kp alto + Bz negativo</span> = Condiciones degradadas
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Condiciones HF por banda -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Condiciones HF por Banda</h5>
            </div>
            <div class="card-body">
                <table class="table table-dark table-sm">
                    <thead>
                        <tr>
                            <th>Banda</th>
                            <th>Dia</th>
                            <th>Noche</th>
                        </tr>
                    </thead>
                    <tbody id="solar-hf-tbody">
                        <tr><td colspan="3" class="text-center text-muted">Cargando datos...</td></tr>
                    </tbody>
                </table>

                <div class="mt-3" style="height: 200px;">
                    <canvas id="grafico-propagacion"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Grafico historico SFI -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Historico SFI (30 dias)</h5>
            </div>
            <div class="card-body">
                <div style="height: 280px;">
                    <canvas id="grafico-historico-solar"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Alertas NOAA -->
    <div class="col-lg-12">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Alertas Espaciales NOAA</h5>
            </div>
            <div class="card-body" id="solar-alertas">
                <div class="text-muted">Cargando alertas...</div>
            </div>
        </div>
    </div>
</div>

<!-- Guia de interpretacion -->
<div class="card bg-dark border-secondary mt-4">
    <div class="card-header bg-dark border-secondary">
        <h5 class="card-title mb-0">Guia de Interpretacion</h5>
    </div>
    <div class="card-body small">
        <div class="row">
            <div class="col-md-4">
                <h6 class="text-light">SFI (Solar Flux Index)</h6>
                <ul class="list-unstyled text-muted">
                    <li><span class="text-success">150+</span> — Propagacion HF excelente en todas las bandas</li>
                    <li><span class="text-warning">90-149</span> — Condiciones moderadas, bandas altas intermitentes</li>
                    <li><span class="text-danger">&lt;90</span> — Propagacion pobre en 10m-15m, mejor en bandas bajas</li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="text-light">Kp Index (0-9)</h6>
                <ul class="list-unstyled text-muted">
                    <li><span class="text-success">0-2</span> — Condiciones geomagneticas tranquilas</li>
                    <li><span class="text-warning">3-4</span> — Perturbacion moderada, posible degradacion</li>
                    <li><span class="text-danger">5+</span> — Tormenta geomagnetica, propagacion HF degradada</li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="text-light">Viento Solar</h6>
                <ul class="list-unstyled text-muted">
                    <li><span class="text-success">&lt;400 km/s</span> — Flujo tranquilo, condiciones normales</li>
                    <li><span class="text-warning">400-600 km/s</span> — Elevado, posibles perturbaciones</li>
                    <li><span class="text-danger">&gt;600 km/s</span> — Alto, probable impacto en HF</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/js/solarDashboard.js" asp-append-version="true"></script>
}
