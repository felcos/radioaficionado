@{
    ViewData["Title"] = "Herramientas";
}

<h2 class="mb-4">Herramientas de Radioaficionado</h2>

<div class="row g-4">

    <!-- Conversor de potencia -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Conversor de Potencia</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Convierte entre dBm, Watts y miliWatts en tiempo real.</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="potencia-dbm" class="form-label">dBm</label>
                        <input type="number" step="any" class="form-control bg-dark text-light border-secondary" id="potencia-dbm" placeholder="ej: 30">
                    </div>
                    <div class="col-md-4">
                        <label for="potencia-watts" class="form-label">Watts</label>
                        <input type="number" step="any" class="form-control bg-dark text-light border-secondary" id="potencia-watts" placeholder="ej: 1">
                    </div>
                    <div class="col-md-4">
                        <label for="potencia-mw" class="form-label">mW</label>
                        <input type="number" step="any" class="form-control bg-dark text-light border-secondary" id="potencia-mw" placeholder="ej: 1000">
                    </div>
                </div>
                <div class="mt-3 small text-muted">
                    <strong>Referencias rapidas:</strong> QRP = 5W (37 dBm) | 100W = 50 dBm | 1 kW = 60 dBm
                </div>
            </div>
        </div>
    </div>

    <!-- Calculadora de distancia entre grids -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Distancia entre Grid Locators</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Calcula distancia y azimut entre dos localizadores Maidenhead.</p>
                <div class="row g-3">
                    <div class="col-md-5">
                        <label for="distancia-grid-a" class="form-label">Grid A</label>
                        <input type="text" class="form-control bg-dark text-light border-secondary" id="distancia-grid-a" placeholder="ej: IN80" maxlength="6">
                    </div>
                    <div class="col-md-5">
                        <label for="distancia-grid-b" class="form-label">Grid B</label>
                        <input type="text" class="form-control bg-dark text-light border-secondary" id="distancia-grid-b" placeholder="ej: FN31" maxlength="6">
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-outline-light w-100" id="btn-calcular-distancia">Calcular</button>
                    </div>
                </div>
                <div class="mt-3 p-2 border border-secondary rounded small" id="resultado-distancia">
                    <span class="text-muted">Introduce dos grid locators y pulsa Calcular.</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Conversor Maidenhead <-> Coordenadas -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Conversor Maidenhead</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Convierte entre grid locator Maidenhead y coordenadas GPS.</p>

                <h6 class="text-light mt-3">Grid a Coordenadas</h6>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <input type="text" class="form-control bg-dark text-light border-secondary" id="maidenhead-grid" placeholder="ej: IN80dk" maxlength="6">
                    </div>
                    <div class="col-4">
                        <button class="btn btn-outline-light w-100" id="btn-grid-a-coord">Convertir</button>
                    </div>
                </div>
                <div class="p-2 border border-secondary rounded small mb-3" id="resultado-grid-coord">
                    <span class="text-muted">Resultado aparecera aqui.</span>
                </div>

                <h6 class="text-light">Coordenadas a Grid</h6>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <input type="number" step="any" class="form-control bg-dark text-light border-secondary" id="maidenhead-lat" placeholder="Latitud">
                    </div>
                    <div class="col-4">
                        <input type="number" step="any" class="form-control bg-dark text-light border-secondary" id="maidenhead-lng" placeholder="Longitud">
                    </div>
                    <div class="col-2">
                        <button class="btn btn-outline-light w-100" id="btn-coord-a-grid">Convertir</button>
                    </div>
                    <div class="col-2">
                        <button class="btn btn-outline-info w-100" id="btn-mi-ubicacion" title="Usar mi ubicacion GPS">GPS</button>
                    </div>
                </div>
                <div class="p-2 border border-secondary rounded small" id="resultado-coord-grid">
                    <span class="text-muted">Resultado aparecera aqui.</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Codigo RST -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Codigo RST (Readability-Strength-Tone)</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Sistema de reportes de senal usado en radioaficion.</p>
                <div class="table-responsive">
                    <table class="table table-dark table-sm table-bordered small">
                        <thead>
                            <tr class="table-secondary">
                                <th>Valor</th>
                                <th>R (Legibilidad)</th>
                                <th>S (Fuerza senal)</th>
                                <th>T (Tono CW)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Ilegible</td><td>Apenas perceptible</td><td>Zumbido extremo AC</td></tr>
                            <tr><td>2</td><td>Apenas legible</td><td>Muy debil</td><td>Zumbido AC muy fuerte</td></tr>
                            <tr><td>3</td><td>Legible con dificultad</td><td>Debil</td><td>Zumbido AC fuerte</td></tr>
                            <tr><td>4</td><td>Legible con esfuerzo</td><td>Aceptable</td><td>Zumbido AC moderado</td></tr>
                            <tr><td>5</td><td>Perfectamente legible</td><td>Moderada</td><td>Tono con ripple musical</td></tr>
                            <tr><td>6</td><td>—</td><td>Buena</td><td>Tono modulado, leve traza</td></tr>
                            <tr><td>7</td><td>—</td><td>Moderadamente fuerte</td><td>Tono cuasi-puro, leve ripple</td></tr>
                            <tr><td>8</td><td>—</td><td>Fuerte</td><td>Tono casi perfecto</td></tr>
                            <tr><td>9</td><td>—</td><td>Extremadamente fuerte</td><td>Tono perfecto</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="small text-muted mt-2">
                    <strong>Ejemplo:</strong> RST 599 = Perfectamente legible, senal extremadamente fuerte, tono perfecto. En fonia (SSB/FM) solo se dan RS (ej: 59).
                </div>
            </div>
        </div>
    </div>

    <!-- Alfabeto fonetico NATO / ICAO -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Alfabeto Fonetico NATO / ICAO</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Usado universalmente en comunicaciones de radio para deletrear indicativos.</p>
                <div class="row small">
                    <div class="col-4">
                        <table class="table table-dark table-sm table-bordered mb-0">
                            <tbody>
                                <tr><td class="text-info fw-bold">A</td><td>Alfa</td></tr>
                                <tr><td class="text-info fw-bold">B</td><td>Bravo</td></tr>
                                <tr><td class="text-info fw-bold">C</td><td>Charlie</td></tr>
                                <tr><td class="text-info fw-bold">D</td><td>Delta</td></tr>
                                <tr><td class="text-info fw-bold">E</td><td>Echo</td></tr>
                                <tr><td class="text-info fw-bold">F</td><td>Foxtrot</td></tr>
                                <tr><td class="text-info fw-bold">G</td><td>Golf</td></tr>
                                <tr><td class="text-info fw-bold">H</td><td>Hotel</td></tr>
                                <tr><td class="text-info fw-bold">I</td><td>India</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-4">
                        <table class="table table-dark table-sm table-bordered mb-0">
                            <tbody>
                                <tr><td class="text-info fw-bold">J</td><td>Juliet</td></tr>
                                <tr><td class="text-info fw-bold">K</td><td>Kilo</td></tr>
                                <tr><td class="text-info fw-bold">L</td><td>Lima</td></tr>
                                <tr><td class="text-info fw-bold">M</td><td>Mike</td></tr>
                                <tr><td class="text-info fw-bold">N</td><td>November</td></tr>
                                <tr><td class="text-info fw-bold">O</td><td>Oscar</td></tr>
                                <tr><td class="text-info fw-bold">P</td><td>Papa</td></tr>
                                <tr><td class="text-info fw-bold">Q</td><td>Quebec</td></tr>
                                <tr><td class="text-info fw-bold">R</td><td>Romeo</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-4">
                        <table class="table table-dark table-sm table-bordered mb-0">
                            <tbody>
                                <tr><td class="text-info fw-bold">S</td><td>Sierra</td></tr>
                                <tr><td class="text-info fw-bold">T</td><td>Tango</td></tr>
                                <tr><td class="text-info fw-bold">U</td><td>Uniform</td></tr>
                                <tr><td class="text-info fw-bold">V</td><td>Victor</td></tr>
                                <tr><td class="text-info fw-bold">W</td><td>Whiskey</td></tr>
                                <tr><td class="text-info fw-bold">X</td><td>X-Ray</td></tr>
                                <tr><td class="text-info fw-bold">Y</td><td>Yankee</td></tr>
                                <tr><td class="text-info fw-bold">Z</td><td>Zulu</td></tr>
                                <tr><td class="text-info fw-bold">0-9</td><td>Se dicen normal</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Plan de bandas resumido -->
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary">
            <div class="card-header bg-dark border-secondary">
                <h5 class="card-title mb-0">Plan de Bandas HF (Resumen IARU R1)</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Referencia rapida de las bandas de radioaficionado en HF.</p>
                <div class="table-responsive">
                    <table class="table table-dark table-sm table-bordered small">
                        <thead>
                            <tr class="table-secondary">
                                <th>Banda</th>
                                <th>Frecuencia</th>
                                <th>Modos principales</th>
                                <th>Propagacion tipica</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>160 m</td><td>1.810 - 2.000 MHz</td><td>CW, SSB, FT8</td><td>Nocturna, NVIS, DX invierno</td></tr>
                            <tr><td>80 m</td><td>3.500 - 3.800 MHz</td><td>CW, SSB, FT8, JS8</td><td>NVIS 200-500 km, DX nocturno</td></tr>
                            <tr><td>60 m</td><td>5.351 - 5.366 MHz</td><td>SSB, Digital</td><td>NVIS, emergencias</td></tr>
                            <tr><td>40 m</td><td>7.000 - 7.200 MHz</td><td>CW, SSB, FT8, RTTY</td><td>Universal dia/noche</td></tr>
                            <tr><td>30 m</td><td>10.100 - 10.150 MHz</td><td>CW, FT8, WSPR</td><td>Estable, solo digital/CW</td></tr>
                            <tr><td>20 m</td><td>14.000 - 14.350 MHz</td><td>CW, SSB, FT8, RTTY</td><td>DX mundial, abierta ~24h</td></tr>
                            <tr><td>17 m</td><td>18.068 - 18.168 MHz</td><td>CW, SSB, FT8</td><td>DX, menos saturada (WARC)</td></tr>
                            <tr><td>15 m</td><td>21.000 - 21.450 MHz</td><td>CW, SSB, FT8</td><td>DX en ciclos solares altos</td></tr>
                            <tr><td>12 m</td><td>24.890 - 24.990 MHz</td><td>CW, SSB, FT8</td><td>Esporadica E, picos solares</td></tr>
                            <tr><td>10 m</td><td>28.000 - 29.700 MHz</td><td>CW, SSB, FM, FT8</td><td>Esporadica E, F2 solar</td></tr>
                            <tr><td>6 m</td><td>50.000 - 52.000 MHz</td><td>CW, SSB, FT8, FM</td><td>Magic band: E-skip, F2</td></tr>
                            <tr><td>2 m</td><td>144.000 - 146.000 MHz</td><td>FM, SSB, CW, FT8</td><td>Local/regional, EME, E-skip</td></tr>
                            <tr><td>70 cm</td><td>430.000 - 440.000 MHz</td><td>FM, DMR, D-STAR, ATV</td><td>Local, satelites, repetidores</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/herramientas.js" asp-append-version="true"></script>
}
