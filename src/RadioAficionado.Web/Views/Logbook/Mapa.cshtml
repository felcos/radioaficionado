@{
    ViewData["Title"] = "Mapa de Contactos";
}

<link rel="stylesheet" href="~/lib/leaflet/leaflet.min.css" />

<style>
    #mapa-contactos {
        height: 75vh;
        min-height: 400px;
        border-radius: 0.5rem;
        border: 1px solid var(--bs-border-color);
    }

    .popup-indicativo {
        font-weight: bold;
        font-size: 1.1em;
        color: #e6a817;
    }

    .popup-tabla {
        margin: 0;
        font-size: 0.85em;
    }

    .popup-tabla td {
        padding: 1px 6px;
    }

    .popup-tabla td:first-child {
        font-weight: 600;
        color: #999;
    }

    #mapa-info {
        font-size: 0.9em;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="text-ra-acento mb-0">Mapa de Contactos</h1>
    <a asp-controller="Logbook" asp-action="Index" class="btn btn-outline-light btn-sm">
        Volver al Logbook
    </a>
</div>

<div id="mapa-info" class="text-ra-suave mb-2">
    Cargando contactos...
</div>

<div id="mapa-contactos"></div>

@section Scripts {
    <script src="~/lib/leaflet/leaflet.min.js"></script>
    <script src="~/js/mapa-contactos.js" asp-append-version="true"></script>
}
