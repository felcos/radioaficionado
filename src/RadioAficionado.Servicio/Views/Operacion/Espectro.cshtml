@{
    ViewData["Title"] = L["Titulo_Espectro"].Value;
    ViewData["Seccion"] = "Espectro";
}

<div class="pagina-panel">
    <div class="pagina-panel-header">
        <h2>@L["Titulo_Espectro"]</h2>
        <span class="espectro-stats">
            @L["Espectro_Mostrando"] <strong id="espectro-total">0</strong> @L["Espectro_Bandas"]
            (<strong id="espectro-ham-count">0</strong> HAM)
        </span>
    </div>
    <div class="pagina-panel-body">
        <!-- Leyenda de colores -->
        <div class="espectro-leyenda">
            <span class="espectro-leyenda-item" style="border-color: #10b981; background: #064e3b;">HAM</span>
            <span class="espectro-leyenda-item" style="border-color: #818cf8; background: #1e1b4b;">Broadcasting</span>
            <span class="espectro-leyenda-item" style="border-color: #f97316; background: #7c2d12;">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Aeronautical" : "Aeronautico")</span>
            <span class="espectro-leyenda-item" style="border-color: #ef4444; background: #450a0a;">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Military" : "Militar")</span>
            <span class="espectro-leyenda-item" style="border-color: #3b82f6; background: #172554;">Telecom</span>
            <span class="espectro-leyenda-item" style="border-color: #a855f7; background: #3b0764;">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Scientific" : "Cientifico")</span>
            <span class="espectro-leyenda-item" style="border-color: #d97706; background: #422006;">ISM/CB</span>
            <span class="espectro-leyenda-item" style="border-color: #78716c; background: #1c1917;">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Pirate" : "Pirata")</span>
        </div>

        <!-- Filtros -->
        <div class="espectro-filtros">
            <label class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="espectro-filtro-ham">
                <span style="color: #10b981; font-weight: 600;">@L["Espectro_SoloBandasHam"]</span>
            </label>
            <select class="form-select form-select-sm" id="espectro-filtro-cat" style="width: auto; display: inline-block;">
                <option value="">@L["Espectro_TodasCategorias"]</option>
                <option value="ham">HAM</option>
                <option value="broadcasting">Broadcasting</option>
                <option value="aeronautico">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Aeronautical" : "Aeronautico")</option>
                <option value="militar">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Military/Security" : "Militar/Seguridad")</option>
                <option value="telecom">Telecom</option>
                <option value="cientifico">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Scientific" : "Cientifico")</option>
                <option value="ism">ISM/CB</option>
                <option value="pirata">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "Pirate" : "Pirata")</option>
            </select>
            <input type="text" class="form-control form-control-sm" id="espectro-buscar"
                   placeholder="@L["Espectro_Buscar"]" style="width: 200px; display: inline-block;">
        </div>

        <!-- Tabla -->
        <div class="espectro-tabla-wrapper">
            <table class="table table-dark table-sm espectro-tabla">
                <thead>
                    <tr>
                        <th style="width: 15%;">@L["Col_Frecuencia"]</th>
                        <th style="width: 10%;">@L["Col_Banda"]</th>
                        <th style="width: 8%;">@L["Col_Longitud"]</th>
                        <th style="width: 40%;">@L["Col_Uso"]</th>
                        <th style="width: 5%;">HAM</th>
                        <th style="width: 22%;">@L["Col_Restricciones"]</th>
                    </tr>
                </thead>
                <tbody id="espectro-tbody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/espectroRadio.js"></script>
}
