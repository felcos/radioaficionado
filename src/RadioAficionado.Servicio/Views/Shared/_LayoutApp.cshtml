<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RadioAficionado</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/sitio.css" />
    <link rel="stylesheet" href="~/css/operacion.css" />
    <link rel="stylesheet" href="~/css/paneles.css" />
    @await RenderSectionAsync("Estilos", required: false)
</head>
<body class="bg-dark text-light">
    <div class="layout-con-sidebar">
        <!-- Sidebar de navegacion -->
        <nav class="sidebar" id="sidebar">
            <button class="sidebar-toggle" id="btn-sidebar-toggle" title="Expandir menu">&#9776;</button>
            <ul class="sidebar-nav">
                <li>
                    <a href="@Url.Action("Index", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Operacion" ? "activa" : "")">
                        <span class="icono">&#128225;</span>
                        <span class="texto-nav">Operacion</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Logbook", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Logbook" ? "activa" : "")">
                        <span class="icono">&#128214;</span>
                        <span class="texto-nav">Logbook</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("DxCluster", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "DxCluster" ? "activa" : "")">
                        <span class="icono">&#128225;</span>
                        <span class="texto-nav">DX Cluster</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Dxcc", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Dxcc" ? "activa" : "")">
                        <span class="icono">&#127758;</span>
                        <span class="texto-nav">DXCC</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Propagacion", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Propagacion" ? "activa" : "")">
                        <span class="icono">&#127774;</span>
                        <span class="texto-nav">Propagacion</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Activaciones", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Activaciones" ? "activa" : "")">
                        <span class="icono">&#9968;</span>
                        <span class="texto-nav">POTA/SOTA</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Contest", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Contest" ? "activa" : "")">
                        <span class="icono">&#127942;</span>
                        <span class="texto-nav">Contest</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Satelites", "Operacion")" class="@(ViewData["Seccion"]?.ToString() == "Satelites" ? "activa" : "")">
                        <span class="icono">&#128752;</span>
                        <span class="texto-nav">Satelites</span>
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Contenido principal -->
        <div class="contenido-principal">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <!-- Sidebar toggle -->
    <script>
        'use strict';
        (function () {
            const sidebar = document.getElementById('sidebar');
            const btnToggle = document.getElementById('btn-sidebar-toggle');
            if (btnToggle && sidebar) {
                btnToggle.addEventListener('click', function () {
                    sidebar.classList.toggle('expandido');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
