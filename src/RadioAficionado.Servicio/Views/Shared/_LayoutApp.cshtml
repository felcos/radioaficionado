                        <span class="icono">&#128225;</span>
                        <span class="texto-nav">@L["Nav_Operacion"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Logbook" })" class="@(ViewData["Seccion"]?.ToString() == "Logbook" ? "activa" : "")">
                        <span class="icono">&#128214;</span>
                        <span class="texto-nav">@L["Nav_Logbook"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "DxCluster" })" class="@(ViewData["Seccion"]?.ToString() == "DxCluster" ? "activa" : "")">
                        <span class="icono">&#128225;</span>
                        <span class="texto-nav">@L["Nav_DxCluster"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Dxcc" })" class="@(ViewData["Seccion"]?.ToString() == "Dxcc" ? "activa" : "")">
                        <span class="icono">&#127758;</span>
                        <span class="texto-nav">@L["Nav_Dxcc"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Propagacion" })" class="@(ViewData["Seccion"]?.ToString() == "Propagacion" ? "activa" : "")">
                        <span class="icono">&#127774;</span>
                        <span class="texto-nav">@L["Nav_Propagacion"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Activaciones" })" class="@(ViewData["Seccion"]?.ToString() == "Activaciones" ? "activa" : "")">
                        <span class="icono">&#9968;</span>
                        <span class="texto-nav">@L["Nav_PotaSota"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Contest" })" class="@(ViewData["Seccion"]?.ToString() == "Contest" ? "activa" : "")">
                        <span class="icono">&#127942;</span>
                        <span class="texto-nav">@L["Nav_Contest"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Satelites" })" class="@(ViewData["Seccion"]?.ToString() == "Satelites" ? "activa" : "")">
                        <span class="icono">&#128752;</span>
                        <span class="texto-nav">@L["Nav_Satelites"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "MapaQsos" })" class="@(ViewData["Seccion"]?.ToString() == "MapaQsos" ? "activa" : "")">
                        <span class="icono">&#127760;</span>
                        <span class="texto-nav">@L["Nav_MapaQsos"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Espectro" })" class="@(ViewData["Seccion"]?.ToString() == "Espectro" ? "activa" : "")">
                        <span class="icono">&#127897;</span>
                        <span class="texto-nav">@L["Nav_Espectro"]</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.RouteUrl("localizada", new { cultura = culturaActual, controller = "Operacion", action = "Herramientas" })" class="@(ViewData["Seccion"]?.ToString() == "Herramientas" ? "activa" : "")">
                        <span class="icono">&#128295;</span>
                        <span class="texto-nav">@L["Nav_Herramientas"]</span>
                    </a>
                </li>
            </ul>
            <!-- Busqueda global -->
            <div class="sidebar-busqueda">
                <input type="text" id="busqueda-global" class="form-control form-control-sm bg-dark text-light"
                       placeholder="Buscar indicativo..." autocomplete="off" />
                <div class="busqueda-resultados" id="busqueda-resultados" style="display:none;"></div>
            </div>

            <!-- Selector de idioma -->
            <div class="sidebar-idioma">
                @{
                    string accionActual = Context.GetRouteValue("action")?.ToString() ?? "Index";
                    string controladorActual = Context.GetRouteValue("controller")?.ToString() ?? "Operacion";
                }
                <a href="@Url.RouteUrl("localizada", new { cultura = otraCultura, controller = controladorActual, action = accionActual })"
                   class="btn-idioma" title="@L["Idioma_Titulo"]">
                    <span class="icono">&#127760;</span>
                    <span class="texto-nav">@otraCulturaTexto</span>
                </a>
            </div>
        </nav>

        <!-- Contenido principal -->
        <div class="contenido-principal">
            @RenderBody()
        </div>
    </div>

    <!-- i18n para JavaScript -->
    <script>
        'use strict';
        window.i18n = {
            cultura: '@culturaActual',
            sinConexion: '@L["Rig_SinConexion"].Value.Replace("'", "\\'")',
            decodificaciones: '@L["Panel_Decodificaciones"].Value.Replace("'", "\\'")',
            transmision: '@L["Panel_Transmision"].Value.Replace("'", "\\'")',
            textoLibre: '@L["TX_TextoLibre"].Value.Replace("'", "\\'")',
            qsoEnCurso: '@L["Panel_QsoEnCurso"].Value.Replace("'", "\\'")',
            indicativo: '@L["QSO_Indicativo"].Value.Replace("'", "\\'")',
            logQso: '@L["QSO_LogQso"].Value.Replace("'", "\\'")',
            buscarIndicativo: '@L["Logbook_BuscarIndicativo"].Value.Replace("'", "\\'")',
            exportarAdif: '@L["Logbook_ExportarAdif"].Value.Replace("'", "\\'")',
            importarAdif: '@L["Logbook_ImportarAdif"].Value.Replace("'", "\\'")',
            arrastraAdif: '@L["Logbook_ArrastraAdif"].Value.Replace("'", "\\'")',
            todasBandas: '@L["DxCluster_TodasBandas"].Value.Replace("'", "\\'")',
            todosModos: '@L["DxCluster_TodosModos"].Value.Replace("'", "\\'")',
            desconectado: '@L["DxCluster_Desconectado"].Value.Replace("'", "\\'")',
            trabajados: '@L["Dxcc_Trabajados"].Value.Replace("'", "\\'")',
            confirmados: '@L["Dxcc_Confirmados"].Value.Replace("'", "\\'")',
            actualizar: '@L["Prop_Actualizar"].Value.Replace("'", "\\'")',
            sinDatos: '@L["Prop_SinDatos"].Value.Replace("'", "\\'")',
            cargando: '@L["Prop_Cargando"].Value.Replace("'", "\\'")',
            buena: '@L["Prop_Buena"].Value.Replace("'", "\\'")',
            regular: '@L["Prop_Regular"].Value.Replace("'", "\\'")',
            mala: '@L["Prop_Mala"].Value.Replace("'", "\\'")',
            cerrada: '@L["Prop_Cerrada"].Value.Replace("'", "\\'")',
            buscarReferencia: '@L["Act_BuscarReferencia"].Value.Replace("'", "\\'")',
            seleccionarContest: '@L["Contest_Seleccionar"].Value.Replace("'", "\\'")',
            iniciarContest: '@L["Contest_Iniciar"].Value.Replace("'", "\\'")',
            seleccionarSatelite: '@L["Sat_Seleccionar"].Value.Replace("'", "\\'")',
            seleccioneSatelite: '@L["Sat_SeleccioneSatelite"].Value.Replace("'", "\\'")',
            conectar: '@L["Config_Conectar"].Value.Replace("'", "\\'")',
            desconectar: '@L["Config_Desconectar"].Value.Replace("'", "\\'")',
            refrescar: '@L["Config_Refrescar"].Value.Replace("'", "\\'")',
            buscar: '@L["Espectro_Buscar"].Value.Replace("'", "\\'")'
        };
    </script>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <!-- Sidebar toggle -->
    <script>
        'use strict';
        (function () {
            const sidebar = document.getElementById('sidebar');
            const btnToggle = document.getElementById('btn-sidebar-toggle');
            const btnMovil = document.getElementById('btn-sidebar-movil');
            const overlay = document.getElementById('sidebar-overlay');

            function cerrarSidebar() {
                if (sidebar) sidebar.classList.remove('expandido');
                if (overlay) overlay.classList.remove('visible');
            }

            function abrirSidebar() {
                if (sidebar) sidebar.classList.add('expandido');
                if (window.innerWidth < 769 && overlay) overlay.classList.add('visible');
            }

            if (btnToggle && sidebar) {
                btnToggle.addEventListener('click', function () {
                    if (sidebar.classList.contains('expandido')) {
                        cerrarSidebar();
                    } else {
                        abrirSidebar();
                    }
                });
            }

            if (btnMovil) {
                btnMovil.addEventListener('click', function () {
                    if (sidebar && sidebar.classList.contains('expandido')) {
                        cerrarSidebar();
                    } else {
                        abrirSidebar();
                    }
                });
            }

            if (overlay) {
                overlay.addEventListener('click', cerrarSidebar);
            }

            // Cerrar sidebar al navegar en movil (click en enlace)
            if (sidebar) {
                const enlaces = sidebar.querySelectorAll('.sidebar-nav a');
                enlaces.forEach(function (enlace) {
                    enlace.addEventListener('click', function () {
                        if (window.innerWidth < 769) cerrarSidebar();
                    });
                });
            }
        })();
    </script>
    <!-- Busqueda global -->
    <script>
        'use strict';
        (function () {
            const input = document.getElementById('busqueda-global');
            const contenedor = document.getElementById('busqueda-resultados');
            if (!input || !contenedor) { return; }

            let timeout = null;

            input.addEventListener('input', function () {
                clearTimeout(timeout);
                const termino = input.value.trim();
                if (termino.length < 2) {
                    contenedor.style.display = 'none';
                    contenedor.innerHTML = '';
                    return;
                }
                timeout = setTimeout(function () {
                    fetch('/api/busqueda?q=' + encodeURIComponent(termino))
                        .then(function (r) { return r.json(); })
                        .then(function (data) { renderizarResultados(data); })
                        .catch(function () { contenedor.style.display = 'none'; });
                }, 300);
            });

            input.addEventListener('blur', function () {
                setTimeout(function () { contenedor.style.display = 'none'; }, 200);
            });
            input.addEventListener('focus', function () {
                if (contenedor.innerHTML) { contenedor.style.display = 'block'; }
            });

            function renderizarResultados(data) {
                let html = '';

                if (data.dxcc) {
                    html += '<div class="busqueda-resultado-titulo">DXCC</div>';
                    html += '<div class="busqueda-resultado-item">';
                    html += '<span class="dato-principal">' + escHtml(data.dxcc.entidad) + '</span>';
                    html += ' <span class="dato-secundario">' + escHtml(data.dxcc.prefijo) + ' &middot; ' +
                            escHtml(data.dxcc.continente) + ' &middot; CQ ' + data.dxcc.zonaCq + '</span>';
                    html += '</div>';
                }

                if (data.logbook && data.logbook.length > 0) {
                    html += '<div class="busqueda-resultado-titulo">Logbook (' + data.logbook.length + ')</div>';
                    for (let i = 0; i < data.logbook.length && i < 10; i++) {
                        const q = data.logbook[i];
                        html += '<div class="busqueda-resultado-item">';
                        html += '<span class="dato-principal">' + escHtml(q.indicativo) + '</span>';
                        html += ' <span class="dato-secundario">' + escHtml(q.fecha) + ' &middot; ' +
                                escHtml(q.banda) + ' &middot; ' + escHtml(q.modo) + '</span>';
                        html += '</div>';
                    }
                }

                if (!html) {
                    html = '<div class="busqueda-resultado-item"><span class="dato-secundario">Sin resultados</span></div>';
                }

                contenedor.innerHTML = html;
                contenedor.style.display = 'block';
            }

            function escHtml(t) {
                const d = document.createElement('div');
                d.textContent = t || '';
                return d.innerHTML;
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
