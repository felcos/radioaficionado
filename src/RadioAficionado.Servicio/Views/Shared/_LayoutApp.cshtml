@{
    string culturaActual = Context.GetRouteValue("cultura")?.ToString() ?? "es";
    string otraCultura = culturaActual == "en" ? "es" : "en";
    string otraCulturaTexto = culturaActual == "en" ? "ES" : "EN";
    string langHtml = culturaActual == "en" ? "en" : "es";
}
<!DOCTYPE html>
<html lang="@langHtml">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RadioAficionado</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/sitio.css" />
    <link rel="stylesheet" href="~/css/operacion.css" />
    <link rel="stylesheet" href="~/css/paneles.css" />
    @await RenderSectionAsync("Estilos", required: false)
</head>
<body class="bg-dark text-light">
    <!-- Boton hamburguesa movil (visible solo en <769px) -->
