<div class="panel-dxcluster-contenido">
    <div class="dxcluster-toolbar">
        <div class="dxcluster-filtros">
            <input type="text" class="form-control form-control-sm" id="dxcluster-filtro-indicativo"
                   placeholder="Indicativo..." style="width: 130px; display: inline-block;" />
            <select class="form-select form-select-sm" id="dxcluster-filtro-banda" style="width: auto; display: inline-block;">
                <option value="">@L["DxCluster_TodasBandas"]</option>
                <option value="160m">160m</option>
                <option value="80m">80m</option>
                <option value="60m">60m</option>
                <option value="40m">40m</option>
                <option value="30m">30m</option>
                <option value="20m">20m</option>
                <option value="17m">17m</option>
                <option value="15m">15m</option>
                <option value="12m">12m</option>
                <option value="10m">10m</option>
                <option value="6m">6m</option>
                <option value="2m">2m</option>
            </select>
            <select class="form-select form-select-sm" id="dxcluster-filtro-modo" style="width: auto; display: inline-block;">
                <option value="">@L["DxCluster_TodosModos"]</option>
                <option value="FT8">FT8</option>
                <option value="CW">CW</option>
                <option value="SSB">SSB</option>
                <option value="RTTY">RTTY</option>
                <option value="FT4">FT4</option>
            </select>
        </div>
        <div class="dxcluster-estado">
            <span class="badge bg-secondary" id="dxcluster-estado-conexion">@L["DxCluster_Desconectado"]</span>
            <span class="dxcluster-contador" id="dxcluster-contador">0 spots</span>
        </div>
    </div>
    <div class="dxcluster-tabla-wrapper">
        <table class="table table-dark table-sm" id="tabla-dxcluster">
            <thead>
                <tr>
                    <th>@L["Col_UTC"]</th>
                    <th>DX</th>
                    <th>Freq</th>
                    <th>@L["Col_Spotter"]</th>
                    <th>@L["Col_Comentario"]</th>
                    <th>DXCC</th>
                </tr>
            </thead>
            <tbody id="dxcluster-tbody">
            </tbody>
        </table>
    </div>
</div>
